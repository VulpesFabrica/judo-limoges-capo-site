---
import Hero from "../../components/Hero.astro";
import Section from "../../components/Section.astro";
import MainLayout from "../../layouts/Layout.astro";
import Card from "../../components/Card.astro";
---

<MainLayout title="Résultats sportifs – CAPO Judo Limoges">
    <Hero
        title="Résultats sportifs"
        subtitle="Les performances des judokas du CAPO Judo Limoges."
        small={true}
    />
    <Section>
        <div class="grid-2">
            <Card>
                <h3>Tournoi de Saint-Léonard</h3>
                <p>
                    <strong>Résultat :</strong><br />
                    2ème – Jules ROUSSEAU (Poussin)
                </p>
                <img
                    src="/images/resultats/tournoi-st-leonard-poussin.jpg"
                    alt="Tournoi de Saint-Léonard – Jules Rousseau"
                    class="result-img"
                />
            </Card>
            <Card>
                <h3>Compétition de Saint-Léonard</h3>
                <p>
                    <strong>Résultat :</strong><br />
                    3ème - Maelle BESSON LAHAYE
                </p>
                <img
                    src="/images/resultats/resultat_st_leonard_04_04_2026.jpg"
                    alt="Compétition de Saint-Léonard – Maelle BESSON LAHAYE"
                    class="result-img"
                />
                <small>Samedi 04 Avril 2026</small>
            </Card>
        </div>
    </Section>
</MainLayout>
---
import MainLayout from "../../layouts/Layout.astro";
---

<MainLayout title="Les Enseignants – CAPO Judo Limoges">
    <section class="hero small-hero">
        <div class="container">
            <h1>Les Enseignants du CAPO Judo Limoges</h1>
            <p>Un encadrement qualifié et passionné pour accompagner chaque judoka.</p>
        </div>
    </section>
    <section class="section">
        <div class="container">
            <h2>Enseignants licenciés au club</h2>
            <div class="grades-group">
                <h3>5ème Dan</h3>
                <ul>
                    <li><strong>Gérard SPESSOTTO</strong></li>
                </ul>
            </div>
            <div class="grades-group">
                <h3>4ème Dan</h3>
                <ul>
                    <li><strong>Laurent MOREAU</strong></li>
                </ul>
            </div>
        </div>
    </section>
    <section class="section section-alt">
        <div class="container">
            <h2>Enseignants non licenciés au club</h2>
            <div class="grades-group">
                <h3>3ème Dan</h3>
                <ul>
                    <li><strong>Jérémy JAMMET</strong></li>
                </ul>
            </div>
            <div class="grades-group">
                <h3>2ème Dan</h3>
                <ul>
                    <li><strong>Loukkhit ROUX</strong></li>
                </ul>
            </div>
        </div>
    </section>
</MainLayout>
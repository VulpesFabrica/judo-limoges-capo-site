---
import MainLayout from "../../layouts/Layout.astro";
---

<MainLayout title="Les Gradés – CAPO Judo Limoges">
    <section class="hero small-hero">
        <div class="container">
            <h1>Les Gradés du CAPO Judo Limoges</h1>
            <p>Les ceintures noires et hauts gradés qui font l’histoire et la fierté du club.</p>
        </div>
    </section>
    <section class="section">
        <div class="container">
            <h2>Gradés licenciés au club</h2>
            <div class="grades-group">
                <h3>5ème Dan</h3>
                <ul>
                    <li><strong>Gérard SPESSOTTO</strong></li>
                </ul>
            </div>
            <div class="grades-group">
                <h3>4ème Dan</h3>
                <ul>
                    <li><strong>Laurent MOREAU</strong></li>
                    <li><strong>Patrick DENANOT</strong></li>
                </ul>
            </div>
            <div class="grades-group">
                <h3>3ème Dan</h3>
                <ul>
                    <li><strong>Roland LACOUR</strong> <span class="badge-memory">En mémoire</span></li>
                </ul>
            </div>
            <div class="grades-group">
                <h3>2ème Dan</h3>
                <ul>
                    <li><strong>Christian BONNEAU</strong></li>
                </ul>
            </div>
            <div class="grades-group">
                <h3>1er Dan</h3>
                <ul>
                    <li><strong>Jean Pierre LEGROS</strong> <span class="badge-memory">En mémoire</span></li>
                    <li><strong>Jean Pierre GOUJAUD</strong></li>
                    <li><strong>Bernard LAMICHE</strong></li>
                    <li><strong>Arsalane BENEMRA</strong></li>
                    <li><strong>Maxime VANONI</strong></li>
                </ul>
            </div>

        </div>
    </section>
    <section class="section section-alt">
        <div class="container">
            <h2>Gradés non licenciés au club</h2>
            <div class="grades-group">
                <h3>3ème Dan</h3>
                <ul>
                    <li><strong>Jérémy JAMMET</strong></li>
                </ul>
            </div>
            <div class="grades-group">
                <h3>2ème Dan</h3>
                <ul>
                    <li><strong>Loukkhit ROUX</strong></li>
                </ul>
            </div>
        </div>
    </section>
</MainLayout>
---
import MainLayout from "../../layouts/Layout.astro";
---

<MainLayout title="Le Club – CAPO Judo Limoges">
    <section class="hero small-hero">
        <div class="hero-content">
            <h1>Le CAPO Judo Limoges</h1>
            <p>Un club engagé pour le développement du judo à Limoges.</p>
        </div>
    </section>
    <section class="section">
        <div class="container grid-2">
            <div class="card">
                <h3>Historique</h3>
                <p>Découvrez l’histoire du club et son évolution.</p>
                <a href="/le-club/historique" class="btn-primary">Lire plus</a>
            </div>
            <div class="card">
                <h3>Le Bureau</h3>
                <p>Les membres qui font vivre le club.</p>
                <a href="/le-club/le-bureau" class="btn-primary">Découvrir</a>
            </div>
            <div class="card">
                <h3>Les Dojos</h3>
                <p>Nos lieux d’entraînement à Limoges.</p>
                <a href="/le-club/les-dojos" class="btn-primary">Voir les lieux</a>
            </div>
            <div class="card">
                <h3>Les Enseignants</h3>
                <p>Encadrement technique et pédagogique du club.</p>
                <a href="/le-club/enseignants" class="btn-primary">Découvrir</a>
            </div>
            <div class="card">
                <h3>Les Gradés</h3>
                <p>Les ceintures noires et hauts gradés du club.</p>
                <a href="/le-club/les-grades" class="btn-primary">Voir les gradés</a>
            </div>
            <div class="card">
                <h3>Compétitions</h3>
                <p>Résultats et engagements sportifs.</p>
                <a href="/le-club/competitions" class="btn-primary">Voir plus</a>
            </div>
        </div>
    </section>
</MainLayout>
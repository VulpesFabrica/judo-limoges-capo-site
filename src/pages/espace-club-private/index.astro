---
import MainLayout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import Section from "../../components/Section.astro";
---
<meta name="robots" content="noindex, nofollow">
<script type="module">
    import identity from "../../scripts/indentity.js";

    const user = identity.currentUser();

    if (!user) {
        window.location.href = "/acces-club";
    }

    const roles = user?.app_metadata?.roles || [];

    if (!roles.includes("admin")) {
        window.location.href = "/";
    }

    document.getElementById("logout")?.addEventListener("click", () => {
        identity.logout();
        window.location.href = "/";
    });
</script>
<MainLayout title="Espace club">
    <Hero
            title="Espace interne du club"
            subtitle="Documents réservés aux responsables"
            small={true}
    />
    <Section>
        <h2>Documents</h2>
        <ul>
            <li>
                <a href="https://docs.google.com/spreadsheets/XXXX" target="_blank">
                    Tableau inscriptions
                </a>
            </li>

            <li>
                <a href="https://docs.google.com/spreadsheets/YYYY" target="_blank">
                    Suivi compétitions
                </a>
            </li>

            <li>
                <a href="https://drive.google.com/XXXXX" target="_blank">
                    Documents administratifs
                </a>
            </li>
        </ul>
        <button id="logout">
            Se déconnecter
        </button>
    </Section>
</MainLayout>
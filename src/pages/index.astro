---
import MainLayout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
import Hero from "../components/Hero.astro";
---

<MainLayout title="CAPO Judo Limoges – Club de Judo à Limoges">
    <Hero
        title="CAPO Judo Limoges"
    >
        <p class="hero-address">
            Situé
            <a
                href="https://www.google.com/maps/search/?api=1&query=25+Avenue+Locarno+87100+Limoges"
                target="_blank"
                rel="noopener"
            >
                25 Avenue Locarno, 87100 Limoges
            </a>
        </p>
        <p>Club Label de Bronze – France Judo</p>
        <img
            src="/images/bronze.png"
            alt="Label Bronze France Judo"
            class="logo-lg"
        />
        <div class="hero-buttons">
            <Button href="/cours-horaires">Voir les horaires</Button>
            <Button href="/le-club" variant="secondary">
                Découvrir le club
            </Button>
        </div>
    </Hero>

    <Section>
        <div class="grid-3">
        </div>
    </Section>

    <Section alt>
        <h2>Horaires des cours</h2>
        <p>Découvrez les créneaux adaptés à chaque âge et niveau.</p>
        <Button href="/cours-horaires">
            Voir tous les horaires
        </Button>
    </Section>

    <Section>
        <h2>Actualités du club</h2>
        <p>Suivez les dernières informations et résultats sportifs.</p>
    </Section>

    <section class="cta">
        <div class="container">
            <h2>Rejoignez le CAPO Judo Limoges</h2>
            <Button href="/contact">
                Nous contacter
            </Button>
        </div>
    </section>
</MainLayout>